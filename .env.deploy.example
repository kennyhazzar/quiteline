AUTH_ENABLED=true
AUTH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
AUTH_TOKEN_TTL=15m
AUTH_REFRESH_TTL=2160h
API_KEYS=frontend:CHANGE_ME_SERVICE_SECRET

POSTGRES_DB=quietline
POSTGRES_USER=quietline
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DSN=postgres://quietline:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/quietline?sslmode=disable

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_CHANNEL_PREFIX=quietline

CORS_ALLOWED_ORIGINS=https://chat.2vault.site

S3_ACCESS_KEY=quietline
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET=quietline

MAX_FILE_BYTES=104861696
WS_CLIENT_BUFFER=256
WS_MAX_MESSAGE_BYTES=65536

# Generate with: go run ./cmd/vapid
VAPID_PUBLIC_KEY=CHANGE_ME_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=CHANGE_ME_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@2vault.site

NEXT_PUBLIC_API_URL=https://api.chat.2vault.site
NEXT_PUBLIC_WS_URL=wss://api.chat.2vault.site
