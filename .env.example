# Local Docker Compose defaults.
# Copy to .env if you want to override compose values.

AUTH_ENABLED=true
AUTH_SECRET=local-compose-secret-change-me
API_KEYS=frontend:dev-secret

POSTGRES_DB=pubsub
POSTGRES_USER=pubsub
POSTGRES_PASSWORD=pubsub
POSTGRES_DSN=postgres://pubsub:pubsub@postgres:5432/pubsub?sslmode=disable

BROKER=redis
REDIS_ADDR=redis:6379
REDIS_CHANNEL_PREFIX=pubsub

CORS_ALLOWED_ORIGINS=http://localhost:3000

S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=zk-messenger
S3_USE_SSL=false

MAX_FILE_BYTES=104861696

NEXT_PUBLIC_API_URL=http://localhost:18080
NEXT_PUBLIC_WS_URL=ws://localhost:18080
